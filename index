<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Permit Status Lookup | Tahoe City Public Utility District</title>
<style>
  :root {
    --lake: #15435C;
    --lake-deep: #0E2F41;
    --granite: #4A4F52;
    --paper: #F6F4EF;
    --moss: #5C7A5E;
    --amber: #C98B3B;
    --line: #D8D4C8;
    --white: #FFFFFF;
    --error: #A23E2E;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--lake-deep);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    line-height: 1.5;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 32px 16px 64px;
  }

  header {
    width: 100%;
    max-width: 560px;
    text-align: center;
    margin-bottom: 28px;
  }

  .eyebrow {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--moss);
    font-weight: 700;
    margin-bottom: 6px;
  }

  h1 {
    font-size: clamp(26px, 5vw, 32px);
    font-weight: 800;
    letter-spacing: -0.01em;
    margin: 0 0 8px;
    color: var(--lake-deep);
  }

  .subtitle {
    color: var(--granite);
    font-size: 16px;
    margin: 0;
  }

  main {
    width: 100%;
    max-width: 560px;
  }

  .card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 28px 24px;
    box-shadow: 0 1px 3px rgba(14, 47, 65, 0.06);
  }

  label {
    display: block;
    font-weight: 700;
    font-size: 15px;
    margin-bottom: 8px;
    color: var(--lake-deep);
  }

  .field-hint {
    font-size: 13px;
    color: var(--granite);
    margin: -2px 0 12px;
  }

  input[type="text"] {
    width: 100%;
    font-size: 17px;
    padding: 14px 16px;
    border: 2px solid var(--line);
    border-radius: 10px;
    background: var(--paper);
    color: var(--lake-deep);
    outline-offset: 2px;
  }

  input[type="text"]:focus {
    border-color: var(--lake);
    outline: 2px solid var(--lake);
    outline-offset: 1px;
  }

  button {
    width: 100%;
    margin-top: 16px;
    padding: 15px 20px;
    font-size: 17px;
    font-weight: 700;
    color: var(--white);
    background: var(--lake);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  button:hover { background: var(--lake-deep); }
  button:focus-visible { outline: 3px solid var(--amber); outline-offset: 2px; }
  button:disabled { background: var(--line); color: var(--granite); cursor: not-allowed; }

  #result {
    margin-top: 24px;
  }

  .result-panel {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }

  .gauge {
    flex-shrink: 0;
    width: 14px;
    height: 88px;
    border-radius: 7px;
    background: var(--line);
    position: relative;
    overflow: hidden;
  }

  .gauge-fill {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    border-radius: 7px;
    transition: height 0.4s ease;
  }

  .result-address {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--granite);
    font-weight: 700;
    margin: 0 0 4px;
  }

  .result-status {
    font-size: 20px;
    font-weight: 800;
    margin: 0 0 6px;
    color: var(--lake-deep);
  }

  .result-date {
    font-size: 14px;
    color: var(--granite);
    margin: 0;
  }

  .result-date span {
    font-variant-numeric: tabular-nums;
  }

  .not-found, .error-state {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 20px;
    font-size: 15px;
    color: var(--granite);
  }

  .error-state {
    background: #FBF1EE;
    border-color: #E8C7BD;
    color: var(--error);
  }

  .loading {
    font-size: 15px;
    color: var(--granite);
    padding: 4px 0;
  }

  footer {
    margin-top: 32px;
    font-size: 13px;
    color: var(--granite);
    text-align: center;
    max-width: 480px;
  }

  footer a { color: var(--lake); }

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .gauge-fill, button { transition: none; }
  }
</style>
</head>
<body>

<header>
  <div class="eyebrow">TCPUD &middot; Permits</div>
  <h1>Check Your Permit Status</h1>
  <p class="subtitle">Enter your service address to see where things stand.</p>
</header>

<main>
  <div class="card">
    <form id="lookup-form" novalidate>
      <label for="street-number">Street number</label>
      <p class="field-hint">Example: 123</p>
      <input
        type="text"
        id="street-number"
        name="street-number"
        inputmode="numeric"
        placeholder="Street number"
        required
        style="margin-bottom:16px;"
      >

      <label for="street-name">Street name</label>
      <p class="field-hint">Example: Elm St, or 9th Ave</p>
      <input
        type="text"
        id="street-name"
        name="street-name"
        placeholder="Street name"
        required
      >
      <button type="submit" id="submit-btn">Check Status</button>
    </form>

    <div id="result" role="status" aria-live="polite"></div>
  </div>
</main>

<footer>
  Questions about your permit? Contact TCPUD Public Affairs.
</footer>

<script>
  // ---------------------------------------------------------------
  // CONFIGURATION
  // Replace this with the HTTP POST URL generated by the Power
  // Automate flow once IT has created it. The flow should accept
  // JSON: { "address": "123 Lakeshore Dr" }
  // and return JSON, e.g.:
  //   Found:     { "found": true, "status": "Approved", "dateReceived": "2026-05-12" }
  //   Not found: { "found": false }
  // ---------------------------------------------------------------
  const FLOW_URL = "https://default3a5cdc1be501475da24830cd5b9a02.cb.environment.api.powerplatform.com:443/powerautomate/automations/direct/workflows/1108a275eb094317a622bfac2dd8d30a/triggers/manual/paths/invoke?api-version=1";

  const STATUS_COLORS = {
    "received":      { fill: "30%",  color: "#C98B3B" },
    "under review":  { fill: "60%",  color: "#15435C" },
    "approved":      { fill: "100%", color: "#5C7A5E" },
    "issued":        { fill: "100%", color: "#5C7A5E" },
    "denied":        { fill: "100%", color: "#A23E2E" }
  };

  function gaugeFor(statusText) {
    const key = (statusText || "").trim().toLowerCase();
    return STATUS_COLORS[key] || { fill: "50%", color: "#15435C" };
  }

  function escapeHtml(str) {
    const div = document.createElement("div");
    div.textContent = str;
    return div.innerHTML;
  }

  function formatDate(dateStr) {
    if (!dateStr) return "";
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return escapeHtml(dateStr);
    return d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
  }

  const form = document.getElementById("lookup-form");
  const resultEl = document.getElementById("result");
  const submitBtn = document.getElementById("submit-btn");

  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    const streetNumber = document.getElementById("street-number").value.trim();
    const streetName = document.getElementById("street-name").value.trim();
    const addressInput = (streetNumber + " " + streetName).trim();
    if (!streetNumber || !streetName) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "Checking...";
    resultEl.innerHTML = '<p class="loading">Looking up your permit...</p>';

    if (FLOW_URL.indexOf("PASTE_") === 0) {
      resultEl.innerHTML =
        '<div class="error-state">This page isn\'t connected to the permit system yet. ' +
        'Contact TCPUD IT to finish setup.</div>';
      submitBtn.disabled = false;
      submitBtn.textContent = "Check Status";
      return;
    }

    try {
      const response = await fetch(FLOW_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ streetNumber: streetNumber, streetName: streetName })
      });

      if (!response.ok) throw new Error("Request failed");

      const data = await response.json();

      if (data && data.found) {
        const gauge = gaugeFor(data.status);
        resultEl.innerHTML =
          '<div class="result-panel">' +
            '<div class="gauge"><div class="gauge-fill" style="height:' + gauge.fill +
              ';background:' + gauge.color + ';"></div></div>' +
            '<div>' +
              '<p class="result-address">' + escapeHtml(addressInput) + '</p>' +
              '<p class="result-status">' + escapeHtml(data.status || "Status unavailable") + '</p>' +
              (data.dateReceived
                ? '<p class="result-date">Received: <span>' + formatDate(data.dateReceived) + '</span></p>'
                : '') +
            '</div>' +
          '</div>';
      } else {
        resultEl.innerHTML =
          '<div class="not-found">We couldn\'t find a permit on file for that address. ' +
          'Double-check the spelling, or contact TCPUD if you believe this is an error.</div>';
      }
    } catch (err) {
      resultEl.innerHTML =
        '<div class="error-state">Something went wrong while checking your permit status. ' +
        'Please try again in a moment.</div>';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Check Status";
    }
  });
</script>

</body>
</html>
